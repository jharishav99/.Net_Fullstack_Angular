using Microsoft.Data.SqlClient;
using System.Data;
using WebApplication1.Models;

namespace WebApplication1.DAL
{
    public class CRUD
    {
        private readonly string _connStr;

        public CRUD(IConfiguration config)
        {
            _connStr = config.GetConnectionString("DefaultConnection");
        }

        public List<Patient> GetPatients()
        {
            List<Patient> patients = new List<Patient>();
            using (SqlConnection con = new SqlConnection(_connStr))
            {
                SqlDataAdapter da = new SqlDataAdapter("SELECT * FROM patients", con);
                DataTable dt = new DataTable();
                da.Fill(dt);

                // Inside the foreach loop in your GetPatients method:
                foreach (DataRow dr in dt.Rows)
                {
                    patients.Add(new Patient
                    {
                        Id = Convert.ToInt32(dr["id"]),
                        Name = dr["name"].ToString() ?? "",
                        Phone = dr["phone"]?.ToString() // <--- ADD THIS LINE
                    });
                
            }
            }
            return patients;
        }

        public void AddPatient(Patient p)
        {
            using (SqlConnection con = new SqlConnection(_connStr))
            {
                string query = "INSERT INTO patients (name, phone) VALUES (@name, @phone)";
                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@name", p.Name);
                cmd.Parameters.AddWithValue("@phone", p.Phone ?? (object)DBNull.Value);

                con.Open();
                cmd.ExecuteNonQuery();
            }
        }
    }
}