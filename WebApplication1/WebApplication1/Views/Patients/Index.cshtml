@model IEnumerable<WebApplication1.Models.Patient>

<div class="container mt-4">
    <h2>Patient List</h2>

    <a asp-action="Create" class="btn btn-success mb-3">Add Patient</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>PatientId</th>
                <th>Name</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Problem</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PatientId</td>
                    <td>@item.Name</td>
                    <td>@item.Age</td>
                    <td>@item.Gender</td>
                    <td>@item.Problem</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.PatientId" class="btn btn-primary btn-sm">Edit</a>

                        <a asp-action="Delete" asp-route-id="@item.PatientId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this record?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
