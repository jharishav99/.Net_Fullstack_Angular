@model IEnumerable<TransportManagement.Models.Booking>

@{
    ViewData["Title"] = "Booking Management Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Booking Management</h2>
            <p class="text-muted">Process passenger reservations and retrieve booking history</p>
        </div>
        <span class="badge bg-primary-soft text-primary p-2 px-3">
            <i class="bi bi-ticket-perforated me-1"></i> Total Bookings: @(Model?.Count() ?? 0)
        </span>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="main-card mb-4 shadow-sm border-0">
                <h5 class="fw-bold mb-3 text-success"><i class="bi bi-plus-circle me-2"></i>Quick Book</h5>
                <form asp-action="BookTrip" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Trip Selection</label>
                        <input name="tripId" type="number" class="form-control" placeholder="Enter Trip ID" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Passenger Selection</label>
                        <input name="passengerId" type="number" class="form-control" placeholder="Enter Passenger ID" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-2 shadow-sm">Confirm Booking</button>
                </form>
            </div>

            <div class="main-card shadow-sm border-0">
                <h5 class="fw-bold mb-3 text-secondary"><i class="bi bi-search me-2"></i>Retrieval Filters</h5>

                <label class="form-label small fw-bold text-uppercase text-muted">By Passenger</label>
                <form asp-action="GetBookingsByPassenger" method="get" class="mb-3">
                    <div class="input-group">
                        <input name="passengerId" type="number" class="form-control border-end-0" placeholder="Passenger ID" />
                        <button class="btn btn-outline-primary" type="submit">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>
                </form>

                <label class="form-label small fw-bold text-uppercase text-muted">By Trip</label>
                <form asp-action="GetBookingsByTrip" method="get" class="mb-3">
                    <div class="input-group">
                        <input name="tripId" type="number" class="form-control border-end-0" placeholder="Trip ID" />
                        <button class="btn btn-outline-primary" type="submit">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>
                </form>

                <hr class="text-muted" />
                <a asp-action="Index" class="btn btn-link btn-sm w-100 text-decoration-none text-muted">
                    <i class="bi bi-arrow-clockwise me-1"></i> Reset to All Bookings
                </a>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="main-card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-secondary small text-uppercase">
                                <th class="ps-3">ID</th>
                                <th>Trip/Passenger</th>
                                <th>Booking Date</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr class="@(item.Status == "Cancelled" ? "opacity-50" : "")">
                                        <td class="ps-3 text-muted small">#@item.BookingID</td>
                                        <td>
                                            <div class="fw-bold text-dark">Trip #@item.TripID</div>
                                            <div class="small text-muted">Passenger #@item.PassengerID</div>
                                        </td>
                                        <td>
                                            <div class="text-dark">@item.BookingDate.ToString("MMM dd, yyyy")</div>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill @(item.Status == "Confirmed" ? "bg-success-soft text-success" : "bg-danger-soft text-danger")">
                                                @item.Status
                                            </span>
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (item.Status != "Cancelled")
                                            {
                                                <form asp-action="CancelBooking" method="post" class="d-inline" onsubmit="return confirm('Cancel this passenger booking?');">
                                                    <input type="hidden" name="bookingId" value="@item.BookingID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-x-circle me-1"></i> Cancel
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small italic">No actions</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="bi bi-journal-x fs-1 d-block mb-3"></i>
                                        No records found for the selected criteria.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>