<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Everest 8848 Travels</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TransportManagement.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-mountain-sun"></i> Everest 8848
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-controller="Bookings" asp-action="Index">
                                <i class="fa-solid fa-ticket"></i> Bookings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-controller="Passengers" asp-action="Index">
                                <i class="fa-solid fa-users"></i> Passengers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-controller="TransportRoutes" asp-action="Index">
                                <i class="fa-solid fa-route"></i> Routes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-controller="Trips" asp-action="Index">
                                <i class="fa-solid fa-calendar-check"></i> Trips
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-controller="Vehicles" asp-action="Index">
                                <i class="fa-solid fa-bus"></i> Fleet
                            </a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto py-3 text-center">
        <div class="container">
            <span class="text-white">🏔️ 2026 Everest 8848 Travels — Nepal Transport Management System</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>