@model IEnumerable<TransportManagement.Models.TransportRoute>

@{
    ViewData["Title"] = "Route Network Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Route Network</h2>
            <p class="text-muted">Define origins, destinations, and logistics distances</p>
        </div>
        <div class="badge bg-primary-soft text-primary p-2 px-3 shadow-sm">
            <i class="bi bi-map-fill me-1"></i> Active Routes: @(Model?.Count() ?? 0)
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="main-card shadow-sm mb-4 border-0">
                <h5 class="fw-bold mb-3 text-primary">
                    <i class="bi bi-plus-square-dotted me-2"></i>Add New Route
                </h5>
                <form asp-action="AddRoute" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Origin (Start)</label>
                        <input name="StartDestination" type="text" class="form-control" placeholder="e.g. New York" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Destination (End)</label>
                        <input name="EndDestination" type="text" class="form-control" placeholder="e.g. Boston" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Distance (km)</label>
                        <div class="input-group">
                            <input name="Distance" type="number" step="0.1" class="form-control" placeholder="0.0" required />
                            <span class="input-group-text">km</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 shadow-sm">
                        <i class="bi bi-geo-alt-fill me-1"></i> Create Route
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="main-card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-secondary small text-uppercase">
                                <th class="ps-3">ID</th>
                                <th>Origin / Start</th>
                                <th>Destination / End</th>
                                <th>Distance</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-3 text-muted small">#@item.RouteID</td>
                                        <td>
                                            <div class="fw-bold text-dark">@item.StartDestination</div>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-primary">@item.EndDestination</div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@item.Distance km</span>
                                        </td>
                                        <td class="text-end pe-3">
                                            <form asp-action="DeleteRoute" method="post" class="d-inline" onsubmit="return confirm('Delete this route? This may affect scheduled trips.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.RouteID" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="bi bi-map fs-1 d-block mb-3"></i>
                                        The route network is empty.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>