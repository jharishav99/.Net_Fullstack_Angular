@model IEnumerable<TransportManagement.Models.Passenger>

@{
    ViewData["Title"] = "Passenger Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Passenger Directory</h2>
            <p class="text-muted">Manage demographics and contact records.</p>
        </div>
        <div class="badge bg-primary-soft text-primary p-2 px-3 shadow-sm">
            <i class="bi bi-people-fill me-1"></i> Total: @(Model?.Count() ?? 0)
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="main-card shadow-sm mb-4 border-0">
                <h5 class="fw-bold mb-3 text-primary">
                    <i class="bi bi-person-plus-fill me-2"></i>Add New Passenger
                </h5>
                <form asp-action="AddPassenger" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">First Name</label>
                        <input name="FirstName" type="text" class="form-control" placeholder="Enter first name" required />
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-uppercase text-muted">Gender</label>
                            <select name="Gender" class="form-select">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-uppercase text-muted">Age</label>
                            <input name="Age" type="number" class="form-control" placeholder="Years" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Email</label>
                        <input name="Email" type="email" class="form-control" placeholder="email@example.com" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Phone Number</label>
                        <input name="PhoneNumber" type="text" class="form-control" placeholder="e.g. +123456789" />
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> Save Passenger
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="main-card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-secondary small text-uppercase">
                                <th class="ps-3">ID</th>
                                <th>Passenger</th>
                                <th>Demographics</th>
                                <th>Contact</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-3 text-muted small">#@item.PassengerID</td>
                                        <td>
                                            <div class="fw-bold text-dark">@item.FirstName</div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@item.Gender</span>
                                            <span class="ms-1 small text-muted">@item.Age yrs</span>
                                        </td>
                                        <td>
                                            <div class="small"><i class="bi bi-envelope text-muted me-1"></i>@item.Email</div>
                                            <div class="small"><i class="bi bi-phone text-muted me-1"></i>@item.PhoneNumber</div>
                                        </td>
                                        <td class="text-end pe-3">
                                            <form asp-action="DeletePassenger" method="post" onsubmit="return confirm('Confirm Delete?');">
                                                <input type="hidden" name="passengerId" value="@item.PassengerID" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="bi bi-person-slash fs-1 d-block mb-2"></i>
                                        No passenger records available.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>